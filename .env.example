# Copie para .env e preencha com valores reais.
# Nunca commite o arquivo .env.

INGRESSINHOS_PUBLIC_URL=https://ingressinhos.seu-dominio.com.br
SENTINEL_AUTH_FRONTEND_PUBLIC_URL=https://auth.seu-dominio.com.br
SENTINEL_AUTH_API_PUBLIC_URL=https://auth-api.seu-dominio.com.br
PAYMENT_PUBLIC_URL=https://payment.seu-dominio.com.br

POSTGRES_PASSWORD=troque-por-uma-senha-forte
POSTGRES_REPLICATION_PASSWORD=troque-por-uma-senha-forte
MONGO_USER=admin
MONGO_PASSWORD=troque-por-uma-senha-forte
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=troque-por-uma-senha-forte

SENTINEL_AUTH_DB_CONNECTION=Host=app-postgres;Port=5432;Database=SentinelAuthDb;Username=postgres;Password=troque-por-uma-senha-forte
PAYMENT_DB_CONNECTION=Host=app-postgres;Port=5432;Database=PaymentDb;Username=postgres;Password=troque-por-uma-senha-forte
INGRESSINHOS_DB_CONNECTION=Host=ingressinhos-postgres-primary;Port=5432;Database=IngressinhosDb;Username=postgres;Password=troque-por-uma-senha-forte
INGRESSINHOS_READ_DB_CONNECTION=Host=ingressinhos-postgres-replica;Port=5432;Database=IngressinhosDb;Username=postgres;Password=troque-por-uma-senha-forte
INGRESSINHOS_MONGO_CONNECTION=mongodb://admin:troque-por-uma-senha-forte@ingressinhos-mongodb:27017/?authSource=admin

SENTINEL_AUTH_JWT_SECRET=troque-por-uma-chave-jwt-com-64-caracteres-ou-mais
SENTINEL_AUTH_INGRESSINHOS_CLIENT_SECRET=troque-por-um-client-secret-forte
SENTINEL_AUTH_INGRESSINHOS_APPLICATION_CLIENT_ID=1
SENTINEL_AUTH_INGRESSINHOS_ADMIN_ROLE_ID=1
SENTINEL_AUTH_INGRESSINHOS_SELLER_ROLE_ID=2
SENTINEL_AUTH_INGRESSINHOS_CLIENT_ROLE_ID=3
SENTINEL_BOOTSTRAP_SUPERADMIN_ENABLED=true
SENTINEL_BOOTSTRAP_SUPERADMIN_EMAIL=admin@seu-dominio.com.br
SENTINEL_BOOTSTRAP_SUPERADMIN_PASSWORD=troque-por-uma-senha-forte
SENTINEL_BOOTSTRAP_SUPERADMIN_NAME=Sentinel SuperAdmin
