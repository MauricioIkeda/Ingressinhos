{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Mongo": {
    "ConnectionString": "",
    "Database": "IngressinhosReadDb",
    "TicketCollection": "clientTickets"
  },
  "Messaging": {
    "Provider": "RabbitMq",
    "BasePath": "..\\message-bus",
    "RabbitMq": {
      "HostName": "localhost",
      "Port": 5672,
      "UserName": "",
      "Password": "",
      "VirtualHost": "/",
      "RequeueOnFailure": false,
      "PrefetchCount": 10,
      "MaxMessagesPerBatch": 50
    }
  },
  "AllowedHosts": "*",
  "SentinelAuthClient": {
    "BaseUrl": "http://localhost:5236",
    "ClientId": "ingressinhos-api",
    "ClientSecret": "",
    "ApplicationClientId": 1,
    "AdminRoleId": 1,
    "SellerRoleId": 2,
    "ClientRoleId": 3
  },
  "PaymentApi": {
    "BaseUrl": "http://localhost:5071"
  },
  "RateLimiting": {
    "Get": {
      "PermitLimit": 60,
      "WindowInSeconds": 60
    },
    "NonGet": {
      "PermitLimit": 15,
      "WindowInSeconds": 60
    }
  },
  "AppSettings": {
    "SecretKey": "",
    "Issuer": "SentinelAuth",
    "Audience": "Ingressinhos.API"
  }
}
