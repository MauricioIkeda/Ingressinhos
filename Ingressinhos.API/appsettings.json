{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=IngressinhosDb;Username=postgres;Password=***REMOVED***"
  },
  "Mongo": {
    "ConnectionString": "mongodb://example:***REMOVED***@localhost:27017/?authSource=admin",
    "Database": "IngressinhosReadDb",
    "TicketCollection": "clientTickets"
  },
  "Messaging": {
    "Provider": "RabbitMq",
    "BasePath": "..\\message-bus",
    "RabbitMq": {
      "HostName": "localhost",
      "Port": 5672,
      "UserName": "admin",
      "Password": "1234",
      "VirtualHost": "/",
      "RequeueOnFailure": false,
      "PrefetchCount": 10,
      "MaxMessagesPerBatch": 50
    }
  },
  "AllowedHosts": "*",
  "SentinelAuthClient": {
    "BaseUrl": "http://localhost:5236",
    "ClientId": "ingressinhos-api",
    "ApplicationClientId": 1,
    "AdminRoleId": 1,
    "SellerRoleId": 2,
    "ClientRoleId": 3
  },
  "PaymentApi": {
    "BaseUrl": "http://localhost:5071"
  },
  "RateLimiting": {
    "Get": {
      "PermitLimit": 60,
      "WindowInSeconds": 60
    },
    "NonGet": {
      "PermitLimit": 15,
      "WindowInSeconds": 60
    }
  },
  "AppSettings": {
    "SecretKey": "***REMOVED_JWT_SECRET***",
    "Issuer": "SentinelAuth",
    "Audience": "Ingressinhos.API"
  }
}
