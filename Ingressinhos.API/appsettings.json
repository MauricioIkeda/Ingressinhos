{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=IngressinhosDb;Username=postgres;Password=1234"
  },
  "Mongo": {
    "ConnectionString": "mongodb://admin:1234@localhost:27017/?authSource=admin",
    "Database": "IngressinhosReadDb",
    "TicketCollection": "clientTickets"
  },
  "Messaging": {
    "Provider": "RabbitMq",
    "BasePath": "..\\message-bus",
    "RabbitMq": {
      "HostName": "localhost",
      "Port": 5672,
      "UserName": "admin",
      "Password": "1234",
      "VirtualHost": "/",
      "RequeueOnFailure": false,
      "PrefetchCount": 10,
      "MaxMessagesPerBatch": 50
    }
  },
  "AllowedHosts": "*",
  "AuthApi": {
    "BaseUrl": "http://localhost:5254"
  },
  "PaymentApi": {
    "BaseUrl": "http://localhost:5071"
  },
  "AppSettings": {
    "SecretKey": "essa-e-a-melhor-senha-do-mundo-123456789",
    "Issuer": "Auth.API",
    "Audience": "Ingressinhos.API"
  }
}
