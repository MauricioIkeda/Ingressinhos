{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "PaymentConnection": "Host=localhost;Database=PaymentDb;Username=postgres;Password=1234"
  },
  "Messaging": {
    "Provider": "RabbitMq", // File para usar o mock, RabbitMq para usar o RabbitMQ real
    "BasePath": "..\\message-bus", // Usado na mensageria mock
    "RabbitMq": {
      "HostName": "localhost",
      "Port": 5672,
      "UserName": "admin",
      "Password": "1234",
      "VirtualHost": "/",
      "RequeueOnFailure": false,
      "PrefetchCount": 10,
      "MaxMessagesPerBatch": 50
    }
  },
  "AllowedHosts": "*"
}
