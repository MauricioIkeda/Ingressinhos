{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "PaymentConnection": ""
  },
  "Messaging": {
    "Provider": "RabbitMq", // File para usar o mock, RabbitMq para usar o RabbitMQ real
    "BasePath": "..\\message-bus", // Usado na mensageria mock
    "RabbitMq": {
      "HostName": "localhost",
      "Port": 5672,
      "UserName": "",
      "Password": "",
      "VirtualHost": "/",
      "RequeueOnFailure": false,
      "PrefetchCount": 10,
      "MaxMessagesPerBatch": 50
    }
  },
  "RateLimiting": {
    "Get": {
      "PermitLimit": 150,
      "WindowInSeconds": 60
    },
    "NonGet": {
      "PermitLimit": 20,
      "WindowInSeconds": 60
    }
  },
  "AllowedHosts": "*"
}
