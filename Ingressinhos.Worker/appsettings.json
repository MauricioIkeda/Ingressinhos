{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Mongo": {
    "ConnectionString": "",
    "Database": "IngressinhosReadDb",
    "TicketCollection": "clientTickets"
  },
  "TicketReadModelBackfill": {
    "EnabledOnStartup": false,
    "BatchSize": 100
  },
  "Messaging": {
    "Provider": "RabbitMq",
    "BasePath": "..\\message-bus",
    "RabbitMq": {
      "HostName": "localhost",
      "Port": 5672,
      "UserName": "",
      "Password": "",
      "VirtualHost": "/",
      "RequeueOnFailure": false,
      "PrefetchCount": 10,
      "MaxMessagesPerBatch": 50
    }
  }
}
